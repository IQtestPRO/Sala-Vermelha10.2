# ===== STAT — variáveis de ambiente =====
# Copie para .env.local (local) e configure no painel da Vercel (produção).

# Banco Turso/libSQL (RECOMENDADO: banco NOVO e separado por ser dado clínico).
# Sem estas variáveis, o app usa um arquivo SQLite local (local.db) — ótimo para dev.
TURSO_DATABASE_URL=libsql://seu-banco.turso.io
TURSO_AUTH_TOKEN=

# Sessão (JWT) — gere um segredo forte (ex.: openssl rand -base64 32)
JWT_SECRET=

# Senha do painel /admin
ADMIN_PASSWORD=

# Segredo do cron de SLA da Vercel (Bearer). Sem ele, /api/cron/sla retorna 401.
CRON_SECRET=

# Vercel Blob (upload de fotos de ECG em produção). Injetado ao conectar um Blob Store.
BLOB_READ_WRITE_TOKEN=

# Web Push (VAPID) — gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:voce@dominio.com

# URL pública do app (para metadados/manifest)
NEXT_PUBLIC_SITE_URL=https://seu-app.vercel.app

# IA de análise de imagem (ECG/monitor) — API da Claude (Anthropic)
# Sem esta chave, a tela "Analisar com IA" avisa que não está configurada.
ANTHROPIC_API_KEY=
# Opcional: trocar o modelo (padrão claude-opus-4-8; use claude-sonnet-4-6 para respostas mais rápidas/baratas)
ANALYZE_MODEL=claude-opus-4-8

# Login fixo opcional: se definir CRM + senha, o app cria um plantonista APROVADO automaticamente
# (em qualquer ambiente) caso esse CRM ainda não exista. Útil para um login pessoal/admin.
SEED_RESPONDER_CRM=
SEED_RESPONDER_PASSWORD=
SEED_RESPONDER_NAME=
SEED_RESPONDER_SPECIALTY=
